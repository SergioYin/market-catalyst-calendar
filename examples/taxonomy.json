    },
    {
      "detail": "records must meet evidence URL count and freshness metadata thresholds",
      "id": "minimum_evidence"
    },
    {
      "detail": "evidence and broker URLs cannot use placeholder or sample hosts/terms",
      "id": "no_placeholder_urls"
    },
    {
      "detail": "strict profile records must include sector, theme, thesis_id, and source_ref",
      "id": "release_metadata"
    },
    {
      "detail": "last_reviewed must exist and fall within the profile freshness window",
      "id": "review_freshness"
    },
    {
